{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# End-to-End Pipeline: MedGemma + ROCOv2
",
    "
",
    "## Overview
",
    "This notebook demonstrates the full workflow:
",
    "1.  Loading the MedGemma model.
",
    "2.  Loading the ROCOv2 dataset.
",
    "3.  Generating captions for medical images.
",
    "4.  Comparing generated captions with ground truth.
",
    "
",
    "## Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os
",
    "import torch
",
    "from dotenv import load_dotenv
",
    "from huggingface_hub import login
",
    "from transformers import AutoProcessor, AutoModelForVision2Seq
",
    "from datasets import load_dataset
",
    "from PIL import Image
",
    "import matplotlib.pyplot as plt
",
    "
",
    "# Load Env
",
    "load_dotenv()
",
    "HF_TOKEN = os.getenv('HF_TOKEN')
",
    "if HF_TOKEN:
",
    "    login(token=HF_TOKEN)
",
    "else:
",
    "    print("Please set HF_TOKEN in .env")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Device Setup
",
    "device = "cuda" if torch.cuda.is_available() else "mps" if torch.backends.mps.is_available() else "cpu"
",
    "print(f"Using device: {device}")
",
    "
",
    "# Load Model
",
    "MODEL_ID = "google/medgemma-1.5-4b-it"
",
    "processor = AutoProcessor.from_pretrained(MODEL_ID)
",
    "model = AutoModelForVision2Seq.from_pretrained(
",
    "    MODEL_ID, 
",
    "    torch_dtype=torch.float16 if device != "cpu" else torch.float32,
",
    "    device_map=None
",
    ").to(device)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load Data
",
    "dataset = load_dataset("eltorio/ROCOv2-radiology", split="train", streaming=True)
",
    "iterator = iter(dataset)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Run Inference
",
    "num_samples = 3
",
    "
",
    "for i in range(num_samples):
",
    "    sample = next(iterator)
",
    "    image = sample['image']
",
    "    truth = sample['caption']
",
    "    
",
    "    # Prompt
",
    "    prompt_text = "<image>
User: Describe this medical image.
Model:"
",
    "    inputs = processor(text=prompt_text, images=image, return_tensors="pt").to(device)
",
    "    
",
    "    # Generate
",
    "    generated_ids = model.generate(**inputs, max_new_tokens=100)
",
    "    generated_text = processor.batch_decode(generated_ids, skip_special_tokens=True)[0]
",
    "    
",
    "    response = generated_text.replace(prompt_text, "").strip()
",
    "    
",
    "    # Display
",
    "    plt.imshow(image)
",
    "    plt.axis('off')
",
    "    plt.show()
",
    "    print(f"Ground Truth: {truth}")
",
    "    print(f"MedGemma: {response}")
",
    "    print("-" * 30)"
   ]
  }
 ],
