{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Dataset Exploration: ROCOv2
",
    "
",
    "## Goal
",
    "Load and visualize the ROCOv2 radiology dataset from Hugging Face to understand its structure and content.
",
    "
",
    "## Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os
",
    "from dotenv import load_dotenv
",
    "from datasets import load_dataset
",
    "import matplotlib.pyplot as plt
",
    "
",
    "# Load env for HF_TOKEN
",
    "load_dotenv()
",
    "
",
    "# Load a streaming version of the dataset to avoid downloading everything at once
",
    "# ROCOv2 is large, so streaming is efficient for exploration.
",
    "dataset_id = "eltorio/ROCOv2-radiology"
",
    "print(f"Loading {dataset_id}...")
",
    "
",
    "try:
",
    "    dataset = load_dataset(dataset_id, split="train", streaming=True)
",
    "    print("Dataset loaded successfully (streaming).")
",
    "except Exception as e:
",
    "    print(f"Error loading dataset: {e}")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Visualizing Samples
",
    "Let's grab the first few examples and display them."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "num_samples = 5
",
    "iterator = iter(dataset)
",
    "
",
    "fig, axes = plt.subplots(1, num_samples, figsize=(20, 5))
",
    "
",
    "for i in range(num_samples):
",
    "    sample = next(iterator)
",
    "    image = sample['image']
",
    "    caption = sample['caption']
",
    "    
",
    "    axes[i].imshow(image)
",
    "    axes[i].axis('off')
",
    "    # Wrap text for better visibility
",
    "    axes[i].set_title(caption[:50] + "...", fontsize=10)
",
    "    
",
    "    print(f"Sample {i+1}:")
",
    "    print(f"Caption: {caption}")
",
    "    print("-" * 50)
",
    "
",
    "plt.show()"
   ]
  }
 ],
